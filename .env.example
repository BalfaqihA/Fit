# Copy this file to `.env.development` (or `.env.production`) and fill in the
# values from Firebase Console → Project settings → Your apps → Web app.
# Expo loads these automatically based on the build profile.
# All keys must be prefixed with EXPO_PUBLIC_ to be readable from JS at runtime.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Once you wire up Sentry (see lib/observability.ts), set the DSN here:
# EXPO_PUBLIC_SENTRY_DSN=
