rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // True iff `claimedOwner` matches the actual `authorId` of the
    // referenced post. Used to prevent clients from spoofing `postOwnerId`
    // on like/comment writes (which would misroute activity notifications).
    function postOwnerMatches(postId, claimedOwner) {
      return get(/databases/$(database)/documents/communityPosts/$(postId)).data.authorId == claimedOwner;
    }

    match /users/{uid} {
      // Public-profile read access: any signed-in user can read a user
      // document so the community search and "other user profile" screens
      // work. Subcollections (workouts, measurements, etc.) remain owner-only.
      allow read: if isSignedIn();
      allow create, update: if isOwner(uid);
      allow delete: if false;

      match /workouts/{workoutId} {
        allow read, create: if isOwner(uid);
        allow update, delete: if false;
      }

      match /measurements/{measurementId} {
        allow read, create: if isOwner(uid);
        allow update, delete: if false;
      }

      match /xp_events/{eventId} {
        allow read, create: if isOwner(uid);
        allow update, delete: if false;
      }

      match /achievements/{achievementId} {
        allow read, create: if isOwner(uid);
        allow update, delete: if false;
      }

      match /plans/{planId} {
        allow read, update: if isOwner(uid);
        allow create, delete: if false;
      }

      // Per-user analytics snapshot maintained by Cloud Functions (admin SDK
      // bypasses these rules on write). Owner can read their own snapshot.
      match /insights/{doc} {
        allow read: if isOwner(uid);
        allow create, update, delete: if false;
      }
    }

    // Community: posts visible to all signed-in users.
    match /communityPosts/{postId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.caption is string
        && request.resource.data.caption.size() <= 500
        && request.resource.data.likeCount == 0
        && request.resource.data.commentCount == 0;

      // Counters (`likeCount`, `commentCount`) are maintained by Firestore
      // triggers in `functions/main.py` and must NOT be writable by clients.
      // Author-only edits cover caption and image; nothing else.
      allow update: if isSignedIn()
        && resource.data.authorId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['caption', 'imageUrl', 'imagePath', 'updatedAt']);

      allow delete: if isOwner(resource.data.authorId);
    }

    match /comments/{commentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.postId is string
        && request.resource.data.text is string
        && request.resource.data.text.size() >= 1
        && request.resource.data.text.size() <= 500
        && request.resource.data.postOwnerId is string
        && postOwnerMatches(
            request.resource.data.postId,
            request.resource.data.postOwnerId
          );
      allow update: if false;
      allow delete: if isOwner(resource.data.authorId);
    }

    // Composite id `{postId}_{uid}` makes one-like-per-user a structural property.
    match /likes/{likeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && likeId == request.resource.data.postId + '_' + request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.postOwnerId is string
        && postOwnerMatches(
            request.resource.data.postId,
            request.resource.data.postOwnerId
          );
      allow update: if false;
      allow delete: if isOwner(resource.data.userId);
    }

    // Reports are write-only for users; moderation reads via the Firebase Console.
    match /reports/{reportId} {
      allow read: if false;
      allow create: if isSignedIn()
        && request.resource.data.reportedBy == request.auth.uid
        && request.resource.data.reason is string
        && request.resource.data.reason.size() >= 1
        && request.resource.data.reason.size() <= 300;
      allow update, delete: if false;
    }

    // ---- Chatbot collections (Gemini-backed) ----
    // All chatbot writes go through Cloud Functions using the admin SDK,
    // which bypasses these rules. Owner-read is what the rules control.

    // Knowledge base — readable by any signed-in user, never client-writable.
    match /fitness_knowledge/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Per-user chat memory — owner-readable. Functions writes via admin SDK.
    match /chat_memory/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    // Per-user daily Gemini usage — owner-readable for quota UIs.
    match /chatbot_usage/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    // Chat sessions and their messages. Each session has a `userId` field
    // that we check on read; clients can NOT write (server is the only
    // writer to keep audit fields tamper-proof).
    match /chat_sessions/{sessionId} {
      allow read: if isSignedIn()
        && resource.data.userId == request.auth.uid;
      allow write: if false;

      match /messages/{messageId} {
        allow read: if isSignedIn()
          && get(/databases/$(database)/documents/chat_sessions/$(sessionId))
              .data.userId == request.auth.uid;
        allow write: if false;
      }
    }

    // User feedback on a specific assistant message. Create-only by the
    // author; reads happen server-side via the admin SDK.
    match /chatbot_feedback/{feedbackId} {
      allow read: if false;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.messageId is string
        && request.resource.data.rating in ['up', 'down']
        && (
          !('reason' in request.resource.data)
          || (request.resource.data.reason is string
              && request.resource.data.reason.size() <= 300)
        );
      allow update, delete: if false;
    }
  }
}
