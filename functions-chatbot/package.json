{
  "name": "fitlife-chatbot-functions",
  "main": "lib/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "copy-intents": "node -e \"require('fs').copyFileSync('src/intents.json','lib/intents.json')\"",
    "build": "tsc && npm run copy-intents",
    "build:watch": "tsc --watch",
    "train": "tsc && npm run copy-intents && node lib/train.js",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions:chatbot"
  },
  "dependencies": {
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^6.0.1",
    "@tensorflow/tfjs": "^4.22.0",
    "natural": "^7.1.0"
  },
  "devDependencies": {
    "typescript": "~5.4.0",
    "@types/node": "^20.0.0",
    "@types/natural": "^5.1.5"
  },
  "private": true
}
