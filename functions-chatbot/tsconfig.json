{
  "compilerOptions": {
    "module": "Node16",
    "target": "es2022",
    "moduleResolution": "node16",
    "lib": ["es2022"],
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "outDir": "lib",
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"],
  "exclude": ["lib", "node_modules"]
}
