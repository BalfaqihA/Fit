rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Allowlist explicit raster image types. The original `image/.*` regex
    // accepted `image/svg+xml`, which can carry executable content if rendered
    // in a WebView, so it is excluded here.
    function isAllowedImageType() {
      return request.resource.contentType in [
        'image/jpeg',
        'image/jpg',
        'image/png',
        'image/webp',
        'image/heic',
        'image/heif'
      ];
    }

    function isAllowedVideoType() {
      return request.resource.contentType in [
        'video/mp4',
        'video/quicktime',
        'video/x-m4v',
        'video/webm'
      ];
    }

    match /communityPosts/{userId}/{file} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && (
          (isAllowedImageType() && request.resource.size < 5 * 1024 * 1024)
          || (isAllowedVideoType() && request.resource.size < 50 * 1024 * 1024)
        );
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/{file} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 3 * 1024 * 1024
        && isAllowedImageType();
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}
